# Production Environment Variables Template
# Copy this file to .env.production and fill in the values

# Superset Core Security
SUPERSET_SECRET_KEY="generate_using_openssl_rand_-base64_42"
SUPERSET_GUEST_TOKEN_SECRET="generate_using_openssl_rand_-base64_42_for_guest_tokens"

# Production Database Connection (RDS)
SUPERSET_DB_HOST="peth_prod.rds.amazonaws.com"
SUPERSET_DB_PORT="5432"
SUPERSET_DB_USER="superset_prod"
SUPERSET_DB_PASS="your_secure_password"
SUPERSET_DB_NAME="superset"

# SSL Configuration for RDS
# Set to 'true' or '1' to enable verify-full with RDS certs
SUPERSET_DB_SSL="true"
SUPERSET_DB_SSL_CERT_PATH="/path/to/global-bundle.pem"

# Constructed URI (for reference, this will be built dynamically in superset_config.py)
# SUPERSET_DATABASE_URI="postgresql+psycopg2://${SUPERSET_DB_USER}:${SUPERSET_DB_PASS}@${SUPERSET_DB_HOST}:${SUPERSET_DB_PORT}/${SUPERSET_DB_NAME}?sslmode=verify-full&sslrootcert=${SUPERSET_DB_SSL_CERT_PATH}"
